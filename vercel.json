{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd frontend/eduplay-frontend && npm run build",
  "outputDirectory": "frontend/eduplay-frontend/dist/eduplay-frontend",
  "devCommand": "cd frontend/eduplay-frontend && npm run start",
  "installCommand": "cd frontend/eduplay-frontend && npm install",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://eduplay-backend-2v0d.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}