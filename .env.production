# ===================================
# EduPlay Production Environment File
# ===================================
# Copy this file to .env and configure for your environment

# ===================================
# Database Configuration (Render PostgreSQL)
# ===================================
# On Render, set DATABASE_URL as an environment variable
# Format: postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://eduplay_user:password@ep-example-123456.us-east-2.aws.neon.tech:5432/eduplay_db

# ===================================
# Spring Boot Configuration
# ===================================
SERVER_PORT=8081
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ===================================
# JWT Configuration
# ===================================
# Generate a strong secret key for production
# openssl rand -base64 64
APP_JWT_SECRET=ChangeThisToAStrongSecretKey_ForProduction_2026!
APP_JWT_EXPIRATION=86400000

# ===================================
# CORS Configuration
# ===================================
# Comma-separated list of allowed origins
APP_CORS_ALLOWED_ORIGINS=https://eduplay-frontend.vercel.app,https://eduplay.vercel.app

# ===================================
# Redis Configuration (Optional - for caching)
# ===================================
# Leave empty to disable Redis (default)
SPRING_DATA_REDIS_HOST=
SPRING_DATA_REDIS_PORT=6379
SPRING_CACHE_TYPE=none

# ===================================
# Ollama Configuration (Optional - for AI question generation)
# ===================================
# Leave empty to disable AI generation (uses static question bank)
OLLAMA_BASE_URL=
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TEMPERATURE=0.25

# ===================================
# Frontend Configuration
# ===================================
# API URL for the frontend to connect to
VITE_API_URL=https://eduplay-backend.onrender.com/api